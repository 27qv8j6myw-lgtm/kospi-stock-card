# 한국투자증권 Open API (KIS Developers)
# https://apiportal.koreainvestment.com/about-howto
# ⚠️ 실제 키는 반드시 이 파일이 아니라 프로젝트 루트의 `.env` 에만 넣으세요.
KIS_APP_KEY=
KIS_APP_SECRET=

# 모의투자: vps (기본) | 실전: prod
KIS_ENV=vps

# 프록시 서버 포트 (Vite가 /api 를 여기로 넘김)
PORT=8787

# 필요 시 추가 (쉼표 구분)
# CORS_ORIGINS=http://localhost:5173

# OpenAI — KIS 없이 이 키만 있어도 /api/ai-fill, POST /api/ai-briefing 동작
# Vercel: Dashboard → Project → Settings → Environment Variables 에 동일 이름으로 추가 후 Redeploy
OPENAI_API_KEY=
# 계정에서 허용된 모델 (예: gpt-4o-mini, gpt-4o). 배포 환경에 맞게 설정.
OPENAI_MODEL=gpt-4o-mini
