# 한국투자증권 Open API (KIS Developers)
# https://apiportal.koreainvestment.com/about-howto
# ⚠️ 실제 키는 반드시 이 파일이 아니라 프로젝트 루트의 `.env` 에만 넣으세요.
KIS_APP_KEY=
KIS_APP_SECRET=

# 모의투자: vps (기본) | 실전: prod
KIS_ENV=vps

# 프록시 서버 포트 (Vite가 /api 를 여기로 넘김)
PORT=8787

# (선택) 스크리닝 강제 갱신 `POST /api/screening` — `Authorization: Bearer <값>` 과 일치해야 함
# ADMIN_SECRET=

# (선택) Vercel 스크리닝 KIS 병렬도 — 1~8 (기본: 로컬 1, Vercel 배포 4). KIS 한도 초과 시 2~3으로 낮춤
# SCREENING_FETCH_CONCURRENCY=4

# (선택) `GET /api/screening-diag` 접근 시 ?secret= 또는 Bearer 로 전달 (미설정 시 진단 엔드포인트 열림)
# SCREENING_DEBUG_SECRET=

# Vercel KV (Upstash) — 미설정 시 로컬은 `.data/screening-kv.json` 파일로 폴백
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# 로컬 UI만 목 데이터로 스크리닝 페이지 확인 (API·KV 없이)
# VITE_SCREENING_USE_MOCK=1

# (선택) 프론트와 API 호스트가 다를 때만 — 빌드에 포함됨. 예: https://kis-proxy.mycompany.com
# VITE_API_BASE_URL=

# 필요 시 추가 (쉼표 구분)
# CORS_ORIGINS=http://localhost:5173

# AI — Anthropic Claude (KIS 없이 키만 있어도 /api/ai-fill, POST /api/ai-briefing, 스크리너 브리핑 동작)
# Vercel: Project → Settings → Environment Variables 에 추가 후 Redeploy
ANTHROPIC_API_KEY=
# 콘솔에서 허용된 모델 ID (기본: claude-opus-4-7, 필요 시 다른 ID로 변경)
ANTHROPIC_MODEL=claude-opus-4-7
# 스크리닝 TOP 3 짧은 분석 전용 (미설정 시 claude-sonnet-4-6 — 40종목 번들과 동일 1h 캐시)
SCREENING_AI_MODEL=claude-sonnet-4-6
# 스크리닝 점수 시 종목명 디버그 (Vercel 로그) — 1이면 종목별 basicInfo 필드 출력
# SCREENING_DEBUG_BASICINFO=1
# (선택) 섹터 스크리닝 딥분석 전용 모델 — 미설정 시 ANTHROPIC_MODEL 사용
# ANTHROPIC_SCREENING_MODEL=claude-opus-4-7
# 종목 리서치(웹 검색) 전용 — tool use에 강한 Sonnet 권장 (예: claude-sonnet-4-5-20250929)
ANTHROPIC_RESEARCH_MODEL=claude-sonnet-4-5
# 투자 메모(3단계) — 대화형 메모 JSON, 도구 없음
ANTHROPIC_MEMO_MODEL=claude-sonnet-4-5
